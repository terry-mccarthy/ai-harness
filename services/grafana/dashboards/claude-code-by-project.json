    {
      "id": 40,
      "title": "Tokens over time \u2014 input vs output vs cache ($project)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total{project_name=~\"$project\",project_branch=~\"$branch\",terminal_type=~\"$terminal\",type=\"input\"}[5m])) * 60",
          "legendFormat": "input"
        },
        {
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total{project_name=~\"$project\",project_branch=~\"$branch\",terminal_type=~\"$terminal\",type=\"output\"}[5m])) * 60",
          "legendFormat": "output"
        },
        {
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total{project_name=~\"$project\",project_branch=~\"$branch\",terminal_type=~\"$terminal\",type=\"cache_read\"}[5m])) * 60",
          "legendFormat": "cache_read"
        },
        {
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total{project_name=~\"$project\",project_branch=~\"$branch\",terminal_type=~\"$terminal\",type=\"cache_creation\"}[5m])) * 60",
          "legendFormat": "cache_creation"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "input"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "output"
