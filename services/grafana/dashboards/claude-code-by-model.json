{
  "title": "Claude Code \u2014 By Model",
  "uid": "claude-code-by-model",
  "tags": [
    "claude-code",
    "telemetry",
    "model"
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(claude_code_token_usage_tokens_total, model)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {}
      },
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(claude_code_token_usage_tokens_total{model=~\"$model\"}, project_name)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {}
      },
      {
        "name": "window",
        "label": "Window",
        "type": "interval",
        "query": "1h,6h,12h,24h,7d",
        "current": {
          "text": "24h",
          "value": "24h"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 41,
      "title": "All-time cost",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total{model=~\"$model\",project_name=~\"$project\"}[$__range]))",
          "legendFormat": "USD"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
