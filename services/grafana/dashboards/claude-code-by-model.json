            "properties": [
              {
                "id": "displayName",
                "value": "Model"
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "model": 0
            }
          }
        }
      ]
    },
    {
      "id": 40,
      "title": "Tokens over time \u2014 input vs output vs cache (by model)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "sum by (model) (rate(claude_code_token_usage_tokens_total{model=~\"$model\",project_name=~\"$project\",type=\"input\"}[5m])) * 60",
          "legendFormat": "{{model}} input"
        },
        {
          "expr": "sum by (model) (rate(claude_code_token_usage_tokens_total{model=~\"$model\",project_name=~\"$project\",type=\"output\"}[5m])) * 60",
          "legendFormat": "{{model}} output"
        },
        {
          "expr": "sum by (model) (rate(claude_code_token_usage_tokens_total{model=~\"$model\",project_name=~\"$project\",type=~\"cache.*\"}[5m])) * 60",
          "legendFormat": "{{model}} cache"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      }
    }
