      "targets": [
        {
          "expr": "sort_desc(sum by (model) (increase(claude_code_token_usage_tokens_total{model=~\"$model\",project_name=~\"$project\"}[$window])))",
          "legendFormat": "{{model}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
