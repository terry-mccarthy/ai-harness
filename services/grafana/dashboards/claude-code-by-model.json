    {
      "id": 30,
      "title": "Token type breakdown by model ($window)",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "sum by (model, type) (increase(claude_code_token_usage_tokens_total{model=~\"$model\",project_name=~\"$project\"}[$window]))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            }
          }
        },
        {
          "id": "groupingToMatrix",
          "options": {
            "columnField": "type",
            "rowField": "model",
            "valueField": "Value"
          }
        }
      ],
      "options": {
        "xField": "model",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "stacking": "normal",
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 31,
      "title": "Per-model summary ($window)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "expr": "sum by (model) (increase(claude_code_token_usage_tokens_total{model=~\"$model\",project_name=~\"$project\"}[$window]))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "Tokens"
        },
        {
          "expr": "sum by (model) (increase(claude_code_cost_usage_USD_total{model=~\"$model\",project_name=~\"$project\"}[$window]))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "Cost"
        },
        {
          "expr": "sum by (model) (increase(claude_code_session_count_total{model=~\"$model\",project_name=~\"$project\"}[$window]))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "Sessions"
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "Tokens",
            "desc": true
          }
        ],
        "footer": {
          "show": true,
          "reducer": [
            "sum"
          ],
          "fields": [
            "Tokens",
            "Cost"
          ]
        }
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value #Tokens"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Tokens"
              },
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #Cost"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Cost (USD)"
              },
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 4
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #Sessions"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Sessions"
              },
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "decimals",
                "value": 0
